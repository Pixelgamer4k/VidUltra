<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- Full-screen camera preview surface -->
    <com.vidultra.pro.ui.AutoFitTextureView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Histogram overlay -->
    <com.vidultra.pro.ui.HistogramView
        android:id="@+id/histogram_view"
        android:layout_width="120dp"
        android:layout_height="64dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_panel"
        android:padding="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Top status bar -->
    <LinearLayout
        android:id="@+id/top_status_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/overlay_light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_resolution"
            style="@style/ValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4K" />

        <TextView
            android:id="@+id/tv_fps"
            style="@style/ValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="24 FPS" />

        <TextView
            android:id="@+id/tv_log_profile"
            style="@style/ValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="REC.709" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_record_time"
            style="@style/ValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:visibility="invisible" />

        <View
            android:id="@+id/recording_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_record_button"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- Left control panel -->
    <LinearLayout
        android:id="@+id/left_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_panel"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/top_status_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar">

        <Button
            android:id="@+id/btn_lens"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:text="@string/lens" />

        <Button
            android:id="@+id/btn_log"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/log_profile" />

        <Button
            android:id="@+id/btn_hdr"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/hdr" />

        <Button
            android:id="@+id/btn_tenbit"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/tenbit" />

        <Button
            android:id="@+id/btn_bitrate"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/bitrate" />

        <Button
            android:id="@+id/btn_stabilization"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/stabilization" />

        <Button
            android:id="@+id/btn_histogram"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/histogram" />

        <Button
            android:id="@+id/btn_focus_bracket"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/focus_bracket" />

        <Button
            android:id="@+id/btn_noise_reduction"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/noise_reduction" />

        <Button
            android:id="@+id/btn_sharpening"
            style="@style/ControlButton"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:text="@string/sharpening" />
    </LinearLayout>

    <!-- Right parameter panel -->
    <LinearLayout
        android:id="@+id/right_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_panel"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/top_status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar">

        <Button
            android:id="@+id/btn_iso"
            style="@style/ControlButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:text="ISO\nAUTO" />

        <Button
            android:id="@+id/btn_shutter"
            style="@style/ControlButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="SHUTTER\nAUTO" />

        <Button
            android:id="@+id/btn_focus"
            style="@style/ControlButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="FOCUS\nAUTO" />

        <Button
            android:id="@+id/btn_wb"
            style="@style/ControlButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="WB\nAUTO" />

        <Button
            android:id="@+id/btn_ev"
            style="@style/ControlButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="EV\n0.0" />

        <Button
            android:id="@+id/btn_fps_select"
            style="@style/ControlButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="FPS\n24" />
    </LinearLayout>

    <!-- Bottom control bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/overlay_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_resolution"
            style="@style/ControlButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/resolution" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_record"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_record_button" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_settings"
            style="@style/ControlButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/settings" />
    </LinearLayout>

    <!-- Parameter adjustment slider overlay -->
    <LinearLayout
        android:id="@+id/slider_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/overlay_dark"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_slider_title"
            style="@style/ValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parameter" />

        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tv_slider_value"
            style="@style/ValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Value" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
